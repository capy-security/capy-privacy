# Capy Privacy - Caddy configuration
# Uses env: API_DOMAIN, DNS_DOMAIN, ADMIN_DOMAIN, IP_ADDRESS, TLS_MODE
# TLS_MODE=off  → local dev (HTTP for API/Admin, no certs needed except DNS core)
# TLS_MODE=on   → production (HTTPS everywhere with cert files)

# -----------------------------------------------------------------------------
# TLS snippets — must be defined before use
# -----------------------------------------------------------------------------

# Local mode: no TLS for API/Admin
(tls_api_off) {
}
(tls_admin_off) {
}

# Production mode: TLS with cert files + HSTS
(tls_api_on) {
	tls /etc/ssl/api/fullchain.pem /etc/ssl/api/privkey.pem
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}
(tls_admin_on) {
	tls /etc/ssl/admin/fullchain.pem /etc/ssl/admin/privkey.pem
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}

# -----------------------------------------------------------------------------
# API - FastAPI backend
# -----------------------------------------------------------------------------
{$API_SCHEME:http://}{$API_DOMAIN:api.localhost} {
	import tls_api_{$TLS_MODE:off}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	reverse_proxy capy_api:8080 {
		header_up Host {http.request.host}
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Forwarded-Port {http.request.port}
		transport http {
			read_timeout 60s
			write_timeout 60s
		}
	}
}

# -----------------------------------------------------------------------------
# Admin (web UI)
# -----------------------------------------------------------------------------
{$ADMIN_SCHEME:http://}{$ADMIN_DOMAIN:admin.localhost} {
	import tls_admin_{$TLS_MODE:off}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	root * /var/capy/admin

	@static path_regexp .*\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp|avif|json)$
	handle @static {
		header Cache-Control "public, max-age=2592000"
		file_server
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}

# -----------------------------------------------------------------------------
# DNS - DoH (always HTTPS — required by protocol)
# -----------------------------------------------------------------------------
{$DNS_DOMAIN:dns.localhost} {
	tls /etc/ssl/dns/fullchain.pem /etc/ssl/dns/privkey.pem

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	root * /var/capy/admin

	handle /dns-query {
		reverse_proxy capy_core:5300 {
			transport http {
				read_timeout 10s
				write_timeout 10s
			}
		}
	}
}

# -----------------------------------------------------------------------------
# Block page (IP) - HTTP
# -----------------------------------------------------------------------------
http://{$IP_ADDRESS:127.0.0.1} {
	root * /var/capy/blocked
	file_server

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
	}
}

# -----------------------------------------------------------------------------
# Block page (IP) - HTTPS (production only)
# -----------------------------------------------------------------------------
import /etc/caddy/ip_https_{$TLS_MODE:off}.conf

# Optional: user-provided config
import /etc/caddy/custom/*.conf
